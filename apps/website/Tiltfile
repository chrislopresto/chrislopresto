config.define_string("session", args=False, usage="Session number (0, 1, 2, ...) to offset ports and avoid collisions")
cfg = config.parse()
session = int(cfg.get("session", "0"))

storybook_port = 6006 + session
dev_port = 5173 + session

local_resource(
  'storybook',
  serve_cmd='pnpm storybook -p %d' % storybook_port,
  links=['http://localhost:%d' % storybook_port],
)
local_resource(
  'dev-server',
  serve_cmd='pnpm dev --port %d' % dev_port,
  links=['http://localhost:%d' % dev_port],
)
local_resource(
  'vitest',
  serve_cmd='pnpm test:watch',
)
local_resource(
  'lint',
  cmd='pnpm lint',
  auto_init=False
)
local_resource(
  'build',
  cmd='pnpm build',
  auto_init=False
)
local_resource(
  'storybook:build',
  cmd='pnpm storybook:build',
  auto_init=False
)
local_resource(
  'serve',
  cmd='pnpm start',
  auto_init=False
)
local_resource(
  '💥',
  cmd='pnpm nuke',
  auto_init=False
)
